# AWS — COG base layers, watersheds, and per-project media/packages in S3
# Bucket layout:
#   {COG_LAYERS keys}              — shared raster layers at bucket root
#   {WATERSHEDS_FGB_KEY}           — watershed boundaries at bucket root
#   {project_id}/media/{file}      — field note photos/videos
#   {project_id}/packages/{...}    — QField package artifacts per project
#
# IAM user needs at least:
#   s3:GetObject, s3:PutObject, s3:DeleteObject on arn:aws:s3:::your-bucket/*
#   (or scoped to arn:aws:s3:::your-bucket/*/media/* and .../packages/*)

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Comma-separated COG keys in the bucket
COG_LAYERS=lulc.cog.tif

# FlatGeobuf watershed boundaries (flat file in the same bucket)
WATERSHEDS_FGB_KEY=watersheds.fbg

# PostGIS — public host QField can reach (NOT localhost for mobile sync)
POSTGIS_PUBLIC_HOST=your-server.example.com
POSTGIS_PUBLIC_PORT=5432

# QField Cloud — each user connects their own account via the Profile page
QFIELD_CLOUD_URL=https://app.qfield.cloud/api/v1/
QFIELD_PROJECT_NAME=dda-diagnose

# QField package rasters — watershed-clipped MBTiles zoom range (smaller = less quota)
QFIELD_RASTER_MIN_ZOOM=8
QFIELD_RASTER_MAX_ZOOM=16
QFIELD_RASTER_MAX_PIXELS=2048

# Database (local dev defaults match docker-compose)
DATABASE_URL=postgresql://geofield:geofield@localhost:5432/dda_product

# Titiler (local dev)
TITILER_URL=http://localhost:8000

# Auth — CORS origin allowed to send credentials, and session cookie settings
FRONTEND_ORIGIN=http://localhost:5173
SESSION_COOKIE_SECURE=false
